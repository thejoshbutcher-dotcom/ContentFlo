# Copy to .env.local and fill in. Until the two NEXT_PUBLIC_SUPABASE_* values
# are set, auth is disabled and CreatorFlo runs purely on localStorage.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Login wall. Fail-secure: ON by default once the Supabase keys above are set.
# Set to "false" only for local development to run on localStorage with no auth.
NEXT_PUBLIC_ENABLE_AUTH=true

# Server-only. Bypasses RLS — never expose to the browser, never prefix NEXT_PUBLIC_.
# Used solely by the Stripe webhook to write entitlements.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (one-time purchase). Added in a later phase.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# Used to build magic-link redirect URLs. Locally: http://localhost:3000.
# On Hostinger (production) set this to https://creatorflo.io.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails that get access without a purchase (owner / comp).
ADMIN_EMAILS=

# Instant dev sign-in (skips the magic-link email). Blocked in production builds
# regardless of value. NEXT_PUBLIC_DEV_LOGIN_EMAIL just pre-fills the dev button.
DEV_LOGIN_EMAILS=
NEXT_PUBLIC_DEV_LOGIN_EMAIL=
